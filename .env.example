# ============================================
# Lumina Promptus — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Google Places API Key (Server-side only, no NEXT_PUBLIC_ prefix)
# Used for: location autocomplete, place details, nearby search
# Get it from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# Google Knowledge Graph API Key (Server-side only)
# Used for: entity recognition & popularity scoring
# Get it from: https://console.cloud.google.com/apis/credentials
GOOGLE_KNOWLEDGE_GRAPH_API_KEY=
